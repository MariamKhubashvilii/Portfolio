---
// StarField.astro
// Generates a static SVG star field at build time — zero JS, zero RAF loops.
// Stars are seeded deterministically so the output is stable across builds.

function mulberry32(seed: number) {
  return function () {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(0xDEADBEEF);

interface Star { x: number; y: number; r: number; a: number; dur: number; delay: number; }

const W = 1440;
const H = 900;

// Regular small stars
const stars: Star[] = Array.from({ length: 220 }, () => ({
  x:     Math.round(rand() * W * 10) / 10,
  y:     Math.round(rand() * H * 10) / 10,
  r:     Math.round((Math.pow(rand(), 2) * 1.4 + 0.25) * 100) / 100,
  a:     Math.round((rand() * 0.45 + 0.1) * 100) / 100,
  dur:   Math.round((rand() * 4 + 3) * 10) / 10,
  delay: Math.round(rand() * 6 * 10) / 10,
}));

// A dozen brighter accent stars
for (let i = 0; i < 14; i++) {
  stars.push({
    x:     Math.round(rand() * W * 10) / 10,
    y:     Math.round(rand() * H * 10) / 10,
    r:     Math.round((rand() * 0.7 + 1.7) * 100) / 100,
    a:     Math.round((rand() * 0.35 + 0.55) * 100) / 100,
    dur:   Math.round((rand() * 3 + 4) * 10) / 10,
    delay: Math.round(rand() * 5 * 10) / 10,
  });
}
---

<svg
  id="starfield"
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${W} ${H}`}
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  {stars.map((s, i) => (
    <circle
      key={i}
      cx={s.x}
      cy={s.y}
      r={s.r}
      fill="white"
      opacity={s.a}
    >
      <animate
        attributeName="opacity"
        values={`${s.a};${Math.round(s.a * 0.25 * 100) / 100};${s.a}`}
        dur={`${s.dur}s`}
        begin={`${s.delay}s`}
        repeatCount="indefinite"
        calcMode="spline"
        keySplines="0.4 0 0.6 1;0.4 0 0.6 1"
        keyTimes="0;0.5;1"
      />
    </circle>
  ))}
</svg>

<style>
  #starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>
