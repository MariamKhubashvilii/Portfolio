---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Marie Khubashvili — ML engineering projects, data science tools, and AI experiments." />
  <title>Projects — Marie Khubashvili</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div id="aurora" aria-hidden="true"></div>
  <StarField />
  <ConstellationCanvas />
  <Nav />

  <main>
    <section class="hero">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow mono">// projects</span>
          <h1>
            What I've built<br>
            <span class="gradient">and found interesting</span>
          </h1>
          <p class="hero-sub">
            ML tools, data experiments, and web apps.<br>
            Some deployed. Some living in notebooks. <br>
            I designed and built this site from scratch. <br>
            Hope the visuals make you stay a little longer. <br>
          </p>
          <a
            href="https://github.com/MariamKhubashvilii"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link mono"
          >
            github.com/MariamKhubashvilii ↗
          </a>
        </div>
        <SolarSystem />
      </div>
    </section>

    <section class="projects">
      <div class="projects-container">
        <div class="projects-group">
          <h2 class="section-heading">Cool projects in active development</h2>
          <p class="section-intro">
            Some projects I'm genuinely excited about, even if they're not finished yet. Ideas too good to sit on. <br>
            If you want to see finished ones, go ahead to the next section.
          </p>
          <div class="grid">
            {activeDevelopment.map((p, i) => (
              <ProjectCard
                title={p.title}
                description={p.description}
                tags={[...p.tags]}
                github={p.github}
                demo={p.demo}
                hasVideo={p.hasVideo}
                demoImage={p.demoImage}
                comingSoon={p.comingSoon}
                page={p.page}
                accent={p.accent}
                index={i}
              />
            ))}
          </div>
        </div>

        <div class="projects-group">
          <h2 class="section-heading">Projects that are finished</h2>
          <div class="grid">
            {finished.map((p, i) => (
              <ProjectCard
                title={p.title}
                description={p.description}
                tags={[...p.tags]}
                github={p.github}
                demo={p.demo}
                hasVideo={p.hasVideo}
                demoImage={p.demoImage}
                comingSoon={p.comingSoon}
                page={p.page}
                accent={p.accent}
                index={i + activeDevelopment.length}
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <footer>
      <span class="mono">marie.dev</span>
      <span class="foot-links">
        <a href="https://github.com/MariamKhubashvilii" target="_blank" rel="noopener noreferrer">github</a>
        <a href="mailto:hello@marie.dev">email</a>
      </span>
    </footer>
  </main>

</body>
</html>

<style>
  main {
    position: relative;
    z-index: 2;
    padding-top: 88px;
  }

  .hero {
    padding: 80px 48px 64px;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .hero-grid {
    display: grid;
    gap: 44px;
  }

  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 80px;
      align-items: center;
    }
  }

  .hero-copy {
    max-width: 680px;
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--mint);
    margin-bottom: 20px;
    opacity: 0.8;
  }

  h1 {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .gradient {
    background: linear-gradient(120deg, var(--purple) 0%, var(--mint) 55%, var(--pink) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 17px;
    color: var(--text-dim);
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .github-link {
    font-size: 12px;
    color: var(--purple);
    letter-spacing: 0.04em;
    opacity: 0.6;
    transition: opacity 0.2s;
    display: inline-block;
  }
  .github-link:hover { opacity: 1; }

  /* Cursor aurora */
  #aurora {
    position: fixed;
    left: 50%;
    top: 50%;
    width: 364px;
    height: 364px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(115, 220, 170, 0.92), rgba(42, 82, 62, 0.68) 15%, transparent 38%),
      radial-gradient(ellipse 180px 120px at 70% 40%, rgba(44, 138, 104, 0.74), rgba(18, 38, 30, 0.38) 28%, transparent 56%),
      radial-gradient(ellipse 160px 100px at 40% 70%, rgba(76, 190, 150, 0.72), rgba(16, 32, 26, 0.24) 32%, transparent 58%);
    filter: blur(90px);
    opacity: 0.855;
    box-shadow:
      inset 0 0 40px rgba(8, 18, 14, 0.35),
      0 0 30px rgba(30, 90, 66, 0.14);
    transition: left 0.12s linear, top 0.12s linear;
  }

  .projects {
    padding: 0 48px 80px;
  }

  .projects-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .projects-group {
    margin-bottom: 60px;
  }

  .projects-group:last-child {
    margin-bottom: 0;
  }

  .section-heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
    color: var(--text);
  }

  .section-heading:has(+ .section-intro) {
    margin-bottom: 16px;
  }

  .section-intro {
    max-width: 680px;
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-dim);
    margin-bottom: 28px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  footer {
    border-top: 0.5px solid var(--border);
    padding: 28px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-faint);
  }

  .foot-links {
    display: flex;
    gap: 24px;
  }

  footer a {
    color: var(--text-faint);
    transition: color 0.2s;
  }
  footer a:hover { color: var(--purple); }

  @media (max-width: 700px) {
    .hero     { padding: 48px 24px 40px; }
    .projects { padding: 0 24px 60px; }
    footer    { padding: 24px; flex-direction: column; gap: 12px; text-align: center; }
    .grid     { grid-template-columns: 1fr; }
    #aurora { display: none; }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const card  = entry.target as HTMLElement;
        const index = Number(card.dataset.index ?? 0);

        setTimeout(() => {
          card.classList.add('visible');
          const rect = card.getBoundingClientRect();
          const x    = rect.left + rect.width  / 2;
          const y    = rect.top  + rect.height / 2;
          (window as any).registerConstellationNode?.(x, y);
        }, index * 110);

        observer.unobserve(card);
      });
    },
    { threshold: 0.15 }
  );

  cards.forEach(card => observer.observe(card));
</script>

<script>
  // Cursor aurora: desktop only
  if (typeof window !== 'undefined' && window.matchMedia('(min-width: 768px)').matches) {
    const aurora = document.getElementById('aurora');
    if (aurora) {
      window.addEventListener('mousemove', (e) => {
        const x = e.clientX;
        const y = e.clientY;
        aurora.style.left = x + 'px';
        aurora.style.top  = y + 'px';
      });
    }
  }
</script>
