---
import Nav from '../../components/Nav.astro';
import StarField from '../../components/StarField.astro';
import ConstellationCanvas from '../../components/ConstellationCanvas.astro';
import '../../styles/global.css';
const demoVideo = '/videos/physics-spring-demo.mp4';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Physics Spring — Marie Khubashvili</title>
    <meta
      name="description"
      content="Physics Spring — an interactive spring simulator with webcam hand tracking, live physics charts, and gesture control."
    />
  </head>
  <body>
    <StarField />
    <ConstellationCanvas />
    <Nav />

    <main class="project-detail-page">
      <section class="project-hero">
        <div class="hero-copy">
          <a href="/" class="back-link mono">← Back to projects</a>
          <span class="eyebrow mono">// project</span>
          <h1>Physics Spring</h1>
          <p class="hero-sub">
            Interactive physics spring simulator with webcam hand tracking, real-time charts, and a custom damped spring engine.
          </p>
          <div class="project-tags">
            <span class="pill">Python</span>
            <span class="pill">OpenCV</span>
            <span class="pill">MediaPipe</span>
            <span class="pill">Matplotlib</span>
          </div>

          <div class="hero-links">
            <a
              class="hero-action"
              href="https://github.com/MariamKhubashvilii/Physics-Spring"
              target="_blank"
              rel="noopener noreferrer"
            >
              View GitHub ↗
            </a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="visual-card">
            <div class="visual-label">Demo</div>
            <video
              class="hero-video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/thumbnails/physics-spring.jpg"
              aria-label="Demonstration of a spring simulation"
            >
              <source src={demoVideo} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
      </section>

      <section class="project-grid">
        <article class="project-card summary-card">
          <h2>Project summary</h2>
          <p>
            Physics Spring is a learning-focused simulator that turns spring motion into an interactive experience. It connects a hand-tracked webcam input with a physics engine so you can pull a mass, change damping, and watch energy transfer in real time.
          </p>
          <div class="summary-list">
            <div>
              <strong>Live controls</strong>
              <p>Control the spring with gestures or a manual panel for `k`, `m`, `b`, and amplitude.</p>
            </div>
            <div>
              <strong>Real-time charts</strong>
              <p>View displacement, velocity, energy, and phase diagrams while the simulation runs.</p>
            </div>
          </div>
        </article>

        <article class="project-card detail-card">
          <h2>What this project shows</h2>
          <ul>
            <li>Spring dynamics with damping and energy transfer.</li>
            <li>Webcam-based hand tracking for gesture control.</li>
            <li>Live updates of physics values and charts.</li>
            <li>Custom rendering and a simple physics engine.</li>
          </ul>
        </article>
      </section>

      <section class="project-section">
        <div class="section-content">
          <h2>How it works</h2>
          <p>
            The simulator uses a damped spring model where force is calculated as <code>F = -kx - bv</code>. A MediaPipe hand tracker reads gestures from the webcam, letting you drag the mass, pause, reset, and switch orientation.
          </p>

          <div class="section-grid">
            <div>
              <h3>Hand controls</h3>
              <ul>
                <li>Point to drag the mass</li>
                <li>Peace sign to change orientation</li>
                <li>Open palm to pause or resume</li>
                <li>Fist to reset</li>
              </ul>
            </div>

            <div>
              <h3>Manual tuning</h3>
              <ul>
                <li>Spring constant <code>k</code></li>
                <li>Mass <code>m</code></li>
                <li>Damping <code>b</code></li>
                <li>Initial amplitude <code>A</code></li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="project-section project-usage">
        <h2>Run it</h2>
        <p>
          Clone the repo, install dependencies, and run <code>python main.py</code>. A webcam is required for gesture interaction, and the UI shows live values plus charts for energy, velocity, and displacement.
        </p>
        <div class="usage-card">
          <div>
            <strong>Dependencies</strong>
            <p>opencv-python, mediapipe, matplotlib, numpy, tkinter</p>
          </div>
          <div>
            <strong>Recommended</strong>
            <p>Python 3.10+, webcam, and good lighting.</p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
  }

  .project-detail-page {
    position: relative;
    z-index: 2;
    padding: 110px 48px 80px;
    max-width: 1180px;
    margin: 0 auto;
  }

  .project-hero {
    display: grid;
    grid-template-columns: 1.1fr 1.3fr;
    gap: 34px;
    align-items: start;
    margin-bottom: 50px;
  }

  .project-hero .back-link {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-dim);
    text-decoration: none;
    opacity: 0.85;
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--mint);
    margin-bottom: 18px;
  }

  .project-hero h1 {
    font-size: clamp(48px, 5vw, 76px);
    line-height: 1.02;
    margin-bottom: 24px;
  }

  .hero-sub {
    max-width: 620px;
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.82;
    margin-bottom: 28px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 14px;
    background: rgba(106, 166, 255, 0.1);
    color: var(--text);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .hero-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: rgba(167, 139, 250, 0.12);
    color: var(--purple);
    border-radius: 999px;
    border: 1px solid rgba(167, 139, 250, 0.18);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .hero-action:hover {
    transform: translateY(-1px);
    background: rgba(167, 139, 250, 0.18);
  }

  .hero-visual {
    display: flex;
    align-items: start;
    justify-content: center;
    margin-top: 96px;
  }

  .visual-card {
    width: 100%;
    border-radius: 32px;
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    border: 0.5px solid rgba(255,255,255,0.08);
    box-shadow: 0 30px 70px rgba(0,0,0,0.18);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .visual-label {
    color: var(--text-dim);
    letter-spacing: 0.08em;
    font-size: 10px;
    text-transform: uppercase;
  }

  .hero-video,
  .demo-player video {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border-radius: 24px;
    object-fit: contain;
    background: rgba(0,0,0,0.06);
  }

  .demo-player {
    margin-top: 24px;
    border-radius: 28px;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    border: 0.5px solid rgba(255,255,255,0.08);
  }

  .visual-placeholder {
    flex: 1;
    border-radius: 24px;
    border: 1px dashed rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.02);
    display: grid;
    place-items: center;
    color: rgba(226,228,240,0.32);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-align: center;
    padding: 26px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
    gap: 20px;
    margin-bottom: 44px;
  }

  .project-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 28px;
    padding: 28px;
  }

  .summary-card h2,
  .detail-card h2,
  .project-section h2 {
    margin-bottom: 18px;
  }

  .summary-card p {
    color: var(--text-dim);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .summary-list {
    display: grid;
    gap: 18px;
  }

  .summary-list strong {
    display: block;
    margin-bottom: 8px;
    color: var(--text);
  }

  .summary-list p,
  .detail-card li,
  .section-content p {
    color: var(--text-dim);
  }

  .detail-card ul,
  .section-content ul {
    display: grid;
    gap: 12px;
    padding-left: 18px;
  }

  .detail-card li,
  .section-content li {
    line-height: 1.8;
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin-top: 24px;
  }

  .project-usage {
    margin-top: 40px;
  }

  .usage-card {
    display: grid;
    gap: 18px;
    padding: 24px;
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
  }

  .usage-card strong {
    display: block;
    margin-bottom: 10px;
    color: var(--text);
  }

  code {
    color: var(--purple);
    background: rgba(167,139,250,0.08);
    border-radius: 8px;
    padding: 2px 6px;
    font-family: var(--mono);
    font-size: 0.95em;
  }

  @media (max-width: 920px) {
    .project-hero,
    .project-grid,
    .section-grid {
      grid-template-columns: 1fr;
    }

    .project-detail-page {
      padding: 100px 24px 60px;
    }
  }

  @media (max-width: 600px) {
    .hero-action {
      width: 100%;
      justify-content: center;
    }

    .project-detail-page {
      padding: 90px 18px 50px;
    }
  }
</style>