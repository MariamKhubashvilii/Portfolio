---
import Nav from '../../components/Nav.astro';
import StarField from '../../components/StarField.astro';
import ConstellationCanvas from '../../components/ConstellationCanvas.astro';
import '../../styles/global.css';

const demoVideo = '/videos/seo-writer-demo.mp4';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SEO Writer — Marie Khubashvili</title>
    <meta
      name="description"
      content="SEO Writer is a multi-mode content optimisation assistant for articles, landing pages, and SEO-first drafting."
    />
  </head>
  <body>
    <div id="aurora" aria-hidden="true"></div>
    <StarField />
    <ConstellationCanvas />
    <Nav />

    <main class="project-detail-page">
      <section class="project-hero">
        <div class="hero-copy">
          <a href="/" class="back-link mono">← Back to projects</a>
          <span class="eyebrow mono">// project</span>
          <h1>SEO Writer</h1>
          <p class="hero-sub">
            A multi-mode writing assistant for SEO-first articles and landing pages, built to turn briefs, keywords, and brand context into structured drafts.
          </p>

          <div class="project-tags">
            <span class="pill">NLP</span>
            <span class="pill">SEO</span>
            <span class="pill">Content Systems</span>
            <span class="pill">GPT</span>
          </div>

          <div class="hero-links">
            <a
              class="hero-action"
              href="https://github.com/MariamKhubashvilii/Brand-Mirror-Upgraded"
              target="_blank"
              rel="noopener noreferrer"
            >
              View GitHub ↗
            </a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="visual-card">
            <div class="visual-label">Demo</div>
            <div class="video-wrap">
              <video
                class="hero-video"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster="/thumbnails/seo-writer.jpg"
                aria-label="Demonstration of the SEO Writer experience"
              >
                <source src={demoVideo} type="video/mp4" />
                Your browser does not support the video tag.
              </video>
              <button class="video-fs" aria-label="Enter full screen">Click here to see the video up close</button>
            </div>
          </div>
        </div>
      </section>

      <section class="project-grid">
        <article class="project-card summary-card">
          <h2>Project summary</h2>
          <p>
            SEO Writer helps shape content from a high-level brief to a polished draft. It combines template-driven writing modes with prompt structure so the output stays clear, searchable, and aligned with a brand’s voice.
          </p>
          <div class="summary-list">
            <div>
              <strong>Structured modes</strong>
              <p>Switch between article drafting, landing page creation, and SEO-focused optimisation flows.</p>
            </div>
            <div>
              <strong>Prompt-first workflow</strong>
              <p>Keep the generator grounded in brand context, keywords, and content goals rather than generic copy.</p>
            </div>
          </div>
        </article>

        <article class="project-card detail-card">
          <h2>What this project shows</h2>
          <ul>
            <li>Template-based content generation for SEO outcomes.</li>
            <li>Content structure that supports both articles and landing pages.</li>
            <li>Prompt design for tone, clarity, and search intent alignment.</li>
            <li>Workflows aimed at faster drafting without losing structure.</li>
          </ul>
        </article>
      </section>

      <section class="project-section">
        <div class="section-content">
          <h2>How it works</h2>
          <p>
            The experience starts with a brief or target keyword, then guides the writer through a structured prompt flow. Each mode produces a draft that is easier to refine because it is organised around headings, intent, and SEO signals.
          </p>

          <div class="section-grid">
            <div>
              <h3>Content modes</h3>
              <ul>
                <li>Article drafting</li>
                <li>Landing page generation</li>
                <li>SEO copy optimisation</li>
                <li>Structured outline creation</li>
              </ul>
            </div>

            <div>
              <h3>What it optimises for</h3>
              <ul>
                <li>Search intent</li>
                <li>Readable structure</li>
                <li>Brand consistency</li>
                <li>Clear call-to-action copy</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="project-section project-usage">
        <h2>Run it</h2>
        <p>
          Clone the repository, install the app dependencies, and configure the model credentials for your preferred LLM backend. The workflow is designed to help you generate draft-ready content quickly and iterate from there.
        </p>
        <div class="usage-card">
          <div>
            <strong>Focus</strong>
            <p>SEO copy, structured generation, and lightweight editorial workflows.</p>
          </div>
          <div>
            <strong>Best for</strong>
            <p>Writers, founders, and teams building faster content pipelines.</p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
  }

  .project-detail-page {
    position: relative;
    z-index: 2;
    padding: 110px 48px 80px;
    max-width: 1180px;
    margin: 0 auto;
  }

  .project-hero {
    display: grid;
    grid-template-columns: 1.1fr 1.3fr;
    gap: 34px;
    align-items: start;
    margin-bottom: 50px;
  }

  .project-hero .back-link {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-dim);
    text-decoration: none;
    opacity: 0.85;
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--mint);
    margin-bottom: 18px;
  }

  .project-hero h1 {
    font-size: clamp(48px, 5vw, 76px);
    line-height: 1.02;
    margin-bottom: 24px;
  }

  .hero-sub {
    max-width: 620px;
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.82;
    margin-bottom: 28px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 14px;
    background: rgba(52, 211, 153, 0.1);
    color: var(--text);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .hero-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: rgba(52, 211, 153, 0.12);
    color: var(--mint);
    border-radius: 999px;
    border: 1px solid rgba(52, 211, 153, 0.18);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .hero-action:hover {
    transform: translateY(-1px);
    background: rgba(52, 211, 153, 0.18);
  }

  .hero-visual {
    display: flex;
    align-items: start;
    justify-content: center;
    margin-top: 96px;
  }

  .visual-card {
    width: 100%;
    border-radius: 32px;
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    border: 0.5px solid rgba(255,255,255,0.08);
    box-shadow: 0 30px 70px rgba(0,0,0,0.18);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .visual-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-family: var(--mono);
  }

  .video-wrap {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
  }

  .video-fs {
    position: absolute;
    right: 12px;
    bottom: 12px;
    background: rgba(0,0,0,0.28);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 8px 12px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.02em;
    cursor: pointer;
    color: transparent;
    background-image: linear-gradient(120deg, var(--purple) 0%, var(--mint) 55%, var(--pink) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    box-shadow: 0 8px 22px rgba(2,6,23,0.45);
    opacity: 0;
    transition: opacity 0.18s ease, transform 0.12s ease;
  }

  .video-wrap:hover .video-fs {
    opacity: 1;
    transform: translateY(-2px);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 24px;
  }

  .project-card {
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    background: rgba(255,255,255,0.025);
    padding: 24px;
  }

  .project-card h2 {
    font-size: 18px;
    margin-bottom: 12px;
  }

  .project-card p,
  .project-card li {
    color: var(--text-dim);
    line-height: 1.8;
    font-size: 14px;
  }

  .summary-list {
    display: grid;
    gap: 16px;
    margin-top: 18px;
  }

  .detail-card ul,
  .section-content ul {
    display: grid;
    gap: 12px;
    padding-left: 18px;
    list-style-position: inside;
    margin: 0;
  }

  .detail-card li,
  .section-content li {
    line-height: 1.8;
    color: var(--text-dim);
  }

  .summary-list strong,
  .section-content h3,
  .usage-card strong {
    color: var(--text);
    display: block;
    margin-bottom: 4px;
  }

  .project-section {
    margin-top: 24px;
    border-top: 0.5px solid rgba(255,255,255,0.06);
    padding-top: 26px;
  }

  .section-content h2,
  .project-usage h2 {
    margin-bottom: 12px;
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 20px;
  }

  .usage-card {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 20px;
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 20px;
    background: rgba(255,255,255,0.02);
  }

  @media (max-width: 900px) {
    .project-hero,
    .project-grid,
    .section-grid,
    .usage-card {
      grid-template-columns: 1fr;
    }

    .project-detail-page {
      padding: 96px 24px 64px;
    }

    .hero-visual {
      margin-top: 0;
    }
  }
</style>

<script>
  (function () {
    function goFullscreen(el) {
      if (!el) return;
      if (el.requestFullscreen) return el.requestFullscreen();
      if (el.webkitRequestFullscreen) return el.webkitRequestFullscreen();
      if (el.msRequestFullscreen) return el.msRequestFullscreen();
    }

    document.addEventListener('click', (e) => {
      const fsBtn = e.target.closest('.video-fs');
      if (fsBtn) {
        const wrap = fsBtn.closest('.video-wrap');
        const vid = wrap && wrap.querySelector('video');
        if (vid) goFullscreen(vid);
      }
    });
  })();
</script>
