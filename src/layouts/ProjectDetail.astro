---
import Nav from '../components/Nav.astro';
import StarField from '../components/StarField.astro';
import ConstellationCanvas from '../components/ConstellationCanvas.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  tags: string[];
  github: string;
  accent: 'purple' | 'mint' | 'pink' | 'blue' | 'amber' | 'emerald';
  demoVideo?: string;
  demoPoster?: string;
  demoImage?: string;
  comingSoon?: boolean;
  visualLabel?: string;
  visualPlaceholder?: string;
}

const {
  title,
  description,
  tags,
  github,
  accent,
  demoVideo,
  demoPoster,
  demoImage,
  comingSoon = false,
  visualLabel = 'Project',
  visualPlaceholder = 'Live demo unavailable',
} = Astro.props;

const accentStyles = {
  purple: {
    eyebrow: 'var(--mint)',
    pill: 'rgba(167, 139, 250, 0.1)',
    action: 'rgba(167, 139, 250, 0.12)',
    actionBorder: 'rgba(167, 139, 250, 0.18)',
    actionHover: 'rgba(167, 139, 250, 0.18)',
    actionText: 'var(--purple)',
  },
  mint: {
    eyebrow: 'var(--mint)',
    pill: 'rgba(110, 231, 183, 0.1)',
    action: 'rgba(110, 231, 183, 0.12)',
    actionBorder: 'rgba(110, 231, 183, 0.18)',
    actionHover: 'rgba(110, 231, 183, 0.18)',
    actionText: 'var(--mint)',
  },
  pink: {
    eyebrow: 'var(--pink)',
    pill: 'rgba(249, 168, 212, 0.1)',
    action: 'rgba(249, 168, 212, 0.12)',
    actionBorder: 'rgba(249, 168, 212, 0.18)',
    actionHover: 'rgba(249, 168, 212, 0.18)',
    actionText: 'var(--pink)',
  },
  blue: {
    eyebrow: 'var(--blue)',
    pill: 'rgba(96, 165, 250, 0.1)',
    action: 'rgba(96, 165, 250, 0.12)',
    actionBorder: 'rgba(96, 165, 250, 0.18)',
    actionHover: 'rgba(96, 165, 250, 0.18)',
    actionText: 'var(--blue)',
  },
  amber: {
    eyebrow: 'var(--amber)',
    pill: 'rgba(251, 191, 36, 0.1)',
    action: 'rgba(251, 191, 36, 0.12)',
    actionBorder: 'rgba(251, 191, 36, 0.18)',
    actionHover: 'rgba(251, 191, 36, 0.18)',
    actionText: 'var(--amber)',
  },
  emerald: {
    eyebrow: 'var(--emerald)',
    pill: 'rgba(52, 211, 153, 0.1)',
    action: 'rgba(52, 211, 153, 0.12)',
    actionBorder: 'rgba(52, 211, 153, 0.18)',
    actionHover: 'rgba(52, 211, 153, 0.18)',
    actionText: 'var(--emerald)',
  },
};

const c = accentStyles[accent];
const videoType = demoVideo?.toLowerCase().endsWith('.mov') ? 'video/quicktime' : 'video/mp4';
const visualHeading = demoVideo ? 'Demo' : demoImage ? 'Screenshot' : comingSoon ? 'Demo' : visualLabel;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Marie Khubashvili</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <StarField />
    <ConstellationCanvas />
    <Nav />

    <main class="project-detail-page">
      <section class="project-hero">
        <div class="hero-copy">
          <a href="/" class="back-link mono">← Back to projects</a>
          <span class="eyebrow mono">// project</span>
          <h1>{title}</h1>
          <p class="hero-sub">{description}</p>

          <div class="project-tags">
            {tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>

          <div class="hero-links">
            <a class="hero-action" href={github} target="_blank" rel="noopener noreferrer">
              View GitHub ↗
            </a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="visual-card">
            <div class="visual-label">{visualHeading}</div>
            {demoVideo ? (
              <div class="video-wrap">
                <video
                  class="hero-video"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  poster={demoPoster}
                  aria-label={`Demonstration of ${title}`}
                >
                  <source src={demoVideo} type={videoType} />
                  Your browser does not support the video tag.
                </video>
                <button class="video-fs" aria-label="Enter full screen">Click here to see the video up close</button>
              </div>
            ) : demoImage ? (
              <div class="image-wrap">
                <img
                  class="hero-image"
                  src={demoImage}
                  alt={`Screenshot of ${title}`}
                  loading="lazy"
                />
                <button class="video-fs image-fs" aria-label="Enlarge screenshot">Click here to see the screenshot up close</button>
              </div>
            ) : comingSoon ? (
              <div class="visual-comingsoon">
                <span class="comingsoon-text">No cool demos yet</span>
                <span class="comingsoon-sub mono">work in progress</span>
              </div>
            ) : (
              <div class="visual-placeholder">{visualPlaceholder}</div>
            )}
          </div>
        </div>
      </section>

      <slot />
    </main>

    {demoImage && (
      <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Enlarged screenshot">
        <button class="lightbox-close" aria-label="Close">×</button>
        <img src={demoImage} alt={`Enlarged screenshot of ${title}`} />
      </div>
    )}
  </body>
</html>

<style define:vars={{
  eyebrowColor: c.eyebrow,
  pillBg: c.pill,
  actionBg: c.action,
  actionBorder: c.actionBorder,
  actionHover: c.actionHover,
  actionText: c.actionText,
}}>
  body {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
  }

  .project-detail-page {
    position: relative;
    z-index: 2;
    padding: 110px 48px 80px;
    max-width: 1180px;
    margin: 0 auto;
  }

  .project-hero {
    display: grid;
    grid-template-columns: 1.1fr 1.3fr;
    gap: 34px;
    align-items: start;
    margin-bottom: 50px;
  }

  .project-hero .back-link {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-dim);
    text-decoration: none;
    opacity: 0.85;
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--eyebrowColor);
    margin-bottom: 18px;
  }

  .project-hero h1 {
    font-size: clamp(48px, 5vw, 76px);
    line-height: 1.02;
    margin-bottom: 24px;
  }

  .hero-sub {
    max-width: 620px;
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.82;
    margin-bottom: 28px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 14px;
    background: var(--pillBg);
    color: var(--text);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .hero-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--actionBg);
    color: var(--actionText);
    border-radius: 999px;
    border: 1px solid var(--actionBorder);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .hero-action:hover {
    transform: translateY(-1px);
    background: var(--actionHover);
  }

  .hero-visual {
    display: flex;
    align-items: start;
    justify-content: center;
    margin-top: 96px;
  }

  .visual-card {
    width: 100%;
    border-radius: 32px;
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    border: 0.5px solid rgba(255,255,255,0.08);
    box-shadow: 0 30px 70px rgba(0,0,0,0.18);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .visual-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-family: var(--mono);
  }

  .video-wrap,
  .image-wrap {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
  }

  .video-fs {
    position: absolute;
    right: 12px;
    bottom: 12px;
    background: rgba(0,0,0,0.28);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 8px 12px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.02em;
    cursor: pointer;
    color: transparent;
    background-image: linear-gradient(120deg, var(--purple) 0%, var(--mint) 55%, var(--pink) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    box-shadow: 0 8px 22px rgba(2,6,23,0.45);
    opacity: 0;
    transition: opacity 0.18s ease, transform 0.12s ease;
  }

  .video-wrap:hover .video-fs,
  .image-wrap:hover .image-fs {
    opacity: 1;
    transform: translateY(-2px);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    place-items: center;
    padding: 40px;
    background: rgba(2, 6, 23, 0.86);
    backdrop-filter: blur(6px);
    cursor: zoom-out;
  }

  .lightbox.open {
    display: grid;
  }

  .lightbox img {
    max-width: 95vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 16px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    cursor: default;
  }

  .lightbox-close {
    position: fixed;
    top: 24px;
    right: 28px;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.08);
    color: var(--text);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    transition: background 0.18s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.16);
  }

  .visual-comingsoon {
    flex: 1;
    min-height: 260px;
    aspect-ratio: 16 / 10;
    border-radius: 20px;
    border: 0.5px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(ellipse at 30% 25%, rgba(167, 139, 250, 0.16), transparent 60%),
      radial-gradient(ellipse at 75% 80%, rgba(249, 168, 212, 0.14), transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-align: center;
    padding: 26px;
  }

  .comingsoon-text {
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 500;
    letter-spacing: -0.01em;
    background: linear-gradient(120deg, var(--purple) 0%, var(--mint) 55%, var(--pink) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .comingsoon-sub {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .visual-placeholder {
    flex: 1;
    min-height: 220px;
    border-radius: 24px;
    border: 1px dashed rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.02);
    display: grid;
    place-items: center;
    color: rgba(226,228,240,0.32);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-align: center;
    padding: 26px;
  }

  :global(.project-grid) {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
    gap: 20px;
    margin-bottom: 44px;
  }

  :global(.project-card) {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 28px;
    padding: 28px;
  }

  :global(.project-card h2) {
    font-size: 18px;
    margin-bottom: 12px;
  }

  :global(.project-card p),
  :global(.project-card li) {
    color: var(--text-dim);
    line-height: 1.8;
    font-size: 14px;
  }

  :global(.summary-list) {
    display: grid;
    gap: 18px;
    margin-top: 18px;
  }

  :global(.summary-list strong),
  :global(.section-content h3),
  :global(.usage-card strong) {
    color: var(--text);
    display: block;
    margin-bottom: 4px;
  }

  :global(.detail-card ul),
  :global(.section-content ul) {
    display: grid;
    gap: 12px;
    padding-left: 18px;
    list-style-position: inside;
    margin: 0;
  }

  :global(.project-section) {
    margin-top: 24px;
    border-top: 0.5px solid rgba(255,255,255,0.06);
    padding-top: 26px;
  }

  :global(.section-content h2),
  :global(.project-usage h2) {
    margin-bottom: 12px;
  }

  :global(.section-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin-top: 24px;
  }

  :global(.project-usage) {
    margin-top: 40px;
  }

  :global(.usage-card) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 20px;
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 20px;
    background: rgba(255,255,255,0.02);
  }

  :global(code) {
    color: var(--purple);
    background: rgba(167,139,250,0.08);
    border-radius: 8px;
    padding: 2px 6px;
    font-family: var(--mono);
    font-size: 0.95em;
  }

  @media (max-width: 920px) {
    .project-hero,
    :global(.project-grid),
    :global(.section-grid),
    :global(.usage-card) {
      grid-template-columns: 1fr;
    }

    .project-detail-page {
      padding: 100px 24px 60px;
    }

    .hero-visual {
      margin-top: 0;
    }
  }

  @media (max-width: 600px) {
    .hero-action {
      width: 100%;
      justify-content: center;
    }

    .project-detail-page {
      padding: 90px 18px 50px;
    }
  }
</style>

{(demoVideo || demoImage) && (
  <script>
    (function () {
      function goFullscreen(el) {
        if (!el) return;
        if (el.requestFullscreen) return el.requestFullscreen();
        if (el.webkitRequestFullscreen) return el.webkitRequestFullscreen();
        if (el.msRequestFullscreen) return el.msRequestFullscreen();
      }

      const lightbox = document.getElementById('lightbox');

      function closeLightbox() {
        if (lightbox) lightbox.classList.remove('open');
      }

      document.addEventListener('click', (e) => {
        const imgBtn = e.target.closest('.image-fs');
        if (imgBtn) {
          if (lightbox) lightbox.classList.add('open');
          return;
        }

        const fsBtn = e.target.closest('.video-fs');
        if (fsBtn) {
          const wrap = fsBtn.closest('.video-wrap');
          const vid = wrap && wrap.querySelector('video');
          if (vid) goFullscreen(vid);
          return;
        }

        if (lightbox && lightbox.classList.contains('open')) {
          if (e.target.closest('.lightbox-close') || !e.target.closest('img')) {
            closeLightbox();
          }
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
      });
    })();
  </script>
)}
